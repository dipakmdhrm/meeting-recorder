# Maintainer: Meeting Recorder <noreply@github.com>
pkgname=meeting-recorder
pkgver=@VERSION@
pkgrel=1
pkgdesc="Meeting recorder with AI transcription and summarization"
arch=('any')
license=('MIT')
depends=(
    'python'
    'python-pip'
    'python-gobject'
    'gtk3'
    'libayatana-appindicator'
    'libnotify'
    'ffmpeg'
    'libpulse'
    'curl'
)
install=meeting-recorder.install
source=("${pkgname}-${pkgver}.tar.gz")
sha256sums=('SKIP')

package() {
    cd "${srcdir}/${pkgname}-${pkgver}"

    install -d "${pkgdir}/opt/meeting-recorder/linux/src"
    cp -r linux/src/. "${pkgdir}/opt/meeting-recorder/linux/src/"
    install -m 644 linux/requirements.txt "${pkgdir}/opt/meeting-recorder/requirements.txt"

    install -Dm 755 linux/packaging/usr/bin/meeting-recorder \
        "${pkgdir}/usr/bin/meeting-recorder"
    install -Dm 644 linux/packaging/usr/share/applications/meeting-recorder.desktop \
        "${pkgdir}/usr/share/applications/meeting-recorder.desktop"
}
